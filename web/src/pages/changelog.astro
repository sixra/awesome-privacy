---
import Layout from '@layouts/Layout.astro';
import Main from '@components/scafold/MainCard.astro';
import ChangelogTimeline from '@components/things/ChangelogTimeline.svelte';
import { fetchChangelog } from '@utils/fetch-changelog';

const changelog = await fetchChangelog();
---

<Layout
	title="Changelog | Awesome Privacy"
	description="A transparent log of all additions, removals, and amendments to the Awesome Privacy list."
>
	<div class="changelog-page">
		<Main>
			<div class="changelog-head">
				<h2>Changelog</h2>
				<a
					class="rss-link"
					href="/rss.xml"
					type="application/rss+xml"
					title="Subscribe to the changelog RSS feed"
				>
					<svg
						aria-hidden="true"
						viewBox="0 0 24 24"
						width="16"
						height="16"
						fill="currentColor"
					>
						<path
							d="M4 11a9 9 0 0 1 9 9h-3a6 6 0 0 0-6-6v-3zm0-7a16 16 0 0 1 16 16h-3A13 13 0 0 0 4 7V4zm2.5 13a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5z"
						></path>
					</svg>
					RSS feed
				</a>
			</div>
			<p>
				All data in awesome-privacy is managed via Git, so that we have a
				complete and transparent changelog of exactly what was added when and by
				whom. The corresponding PR for each change contains full details and
				justifications.
			</p>
			{
				changelog.entries.length > 0 ? (
					<ChangelogTimeline
						client:load
						entries={changelog.entries}
						rejections={changelog.rejections || []}
					/>
				) : (
					<p class="fallback">Changelog data is currently unavailable.</p>
				)
			}
		</Main>
	</div>
</Layout>

<style lang="scss">
	.changelog-head {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: var(--space-md);
		flex-wrap: wrap;
	}
	h2 {
		font-size: var(--text-3xl);
		margin: 0;
	}
	.rss-link {
		display: inline-flex;
		align-items: center;
		gap: var(--space-xs);
		font-family: var(--font-subtitle);
		font-size: var(--text-sm);
		font-weight: bold;
		text-decoration: none;
		color: var(--accent-fg);
		background: var(--accent-3);
		border: var(--border-light);
		box-shadow: var(--shadow-sm);
		padding: var(--space-xs) var(--space-md);
		transition: var(--transition-normal);
		&:hover {
			box-shadow: var(--shadow-sm-hover);
		}
	}
	p {
		font-size: var(--text-md);
		margin: 0 0 var(--space-md) 0;
	}
	.fallback {
		text-align: center;
		opacity: var(--opacity-muted);
	}
</style>
