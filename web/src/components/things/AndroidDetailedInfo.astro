---
import type { AndroidInfo } from '@utils/fetch-android-info';
import type { PlexusInfo, PlexusRomSummary } from '@utils/fetch-plexus-info';
import { formatDate, timeAgo } from '@utils/dates-n-stuff';
import FontAwesome from '@components/form/FontAwesome.svelte';

interface Props {
	androidData?: AndroidInfo | null;
	plexusData?: PlexusInfo | null;
}

const { androidData, plexusData } = Astro.props;

function permissionToReadable(permission: string): string {
	return (permission.split('.').pop() || '')
		.replace(/_/g, ' ')
		.toLowerCase()
		.split(' ')
		.map((word) => word.charAt(0).toUpperCase() + word.slice(1))
		.join(' ');
}

function scoreClass(numerator: number, denominator: number): string {
	const ratio = denominator ? numerator / denominator : 0;
	if (ratio >= 0.75) return 'score score-good';
	if (ratio >= 0.5) return 'score score-okay';
	return 'score score-bad';
}

const ratingLabel = (t: 'native' | 'micro_g') =>
	t === 'native' ? 'Native' : 'microG';

const SOURCE_LABELS: Record<string, string> = {
	fdroid: 'F-Droid',
	google_play: 'Play Store',
	google_play_alternative: 'Aurora / alt',
	manual: 'Manual install',
};
const formatSource = (s: string): string =>
	SOURCE_LABELS[s] ||
	s.replace(/_/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());

const romTooltip = (rom: PlexusRomSummary): string | undefined => {
	const entries = Object.entries(rom.sources);
	if (!entries.length) return undefined;
	return `Installed via ${entries
		.map(([k, v]) => `${formatSource(k)} (${v})`)
		.join(', ')}`;
};

const androidRange = (v?: PlexusInfo['androidVersions']): string | null => {
	if (!v) return null;
	return v.min === v.max ? `Android ${v.min}` : `Android ${v.min}–${v.max}`;
};

const exodusReportUrl = (report?: number) =>
	report ? `https://reports.exodus-privacy.eu.org/en/reports/${report}/` : null;

const hasAndroid = !!androidData && !androidData.error;
const hasPlexusScores =
	!!plexusData && !!(plexusData.scores.native || plexusData.scores.micro_g);

const tested = androidRange(plexusData?.androidVersions);
const reportUrl = hasAndroid ? exodusReportUrl(androidData!.report) : null;
---

<div class="android-info-wrapper">
	<div class="left">
		{
			hasAndroid && (
				<div class="info-section">
					<h4>APK Info</h4>
					<ul class="list-table">
						<li>
							<span class="lbl">App</span>
							<span class="val">
								<a
									href={`https://play.google.com/store/apps/details?id=${androidData!.handle}`}
								>
									{androidData!.app_name}
								</a>
							</span>
						</li>
						<li>
							<span class="lbl">Creation Date</span>
							<span class="val" title={`${timeAgo(androidData!.created)} ago`}>
								{formatDate(androidData!.created)}
							</span>
						</li>
						<li>
							<span class="lbl">Last Updated</span>
							<span class="val" title={`${timeAgo(androidData!.updated)} ago`}>
								{formatDate(androidData!.updated)}
							</span>
						</li>
						<li>
							<span class="lbl">Current Version</span>
							<span
								class="val"
								title={`Build code: ${androidData!.version_code}`}
							>
								{androidData!.version_name}
							</span>
						</li>
						{androidData!.creator && (
							<li>
								<span class="lbl">Creator</span>
								<span class="val">{androidData!.creator}</span>
							</li>
						)}
						{androidData!.downloads && (
							<li>
								<span class="lbl">Downloads</span>
								<span class="val">{androidData!.downloads}</span>
							</li>
						)}
						{reportUrl && (
							<li>
								<span class="lbl">Privacy Report</span>
								<span class="val">
									<a href={reportUrl} target="_blank" rel="noopener">
										View on Exodus →
									</a>
								</span>
							</li>
						)}
					</ul>
				</div>
			)
		}

		{
			hasPlexusScores && (
				<div class="info-section de-googled">
					<h4>De-Googled Compatibility</h4>
					<div class="plexus-cards">
						{plexusData!.scores.native && (
							<div
								class="plexus-card"
								title="How well the app runs on a de-Googled ROM with no Google Services"
							>
								<span class="plexus-card-lbl">Native</span>
								<span
									class={scoreClass(
										plexusData!.scores.native.numerator,
										plexusData!.scores.native.denominator,
									)}
								>
									{plexusData!.scores.native.numerator.toFixed(2)}
									<span class="score-denom">
										/ {plexusData!.scores.native.denominator}
									</span>
								</span>
								<span class="plexus-card-meta">
									{plexusData!.scores.native.total_count} ratings
								</span>
							</div>
						)}
						{plexusData!.scores.micro_g && (
							<div
								class="plexus-card"
								title="How well the app runs on a de-Googled ROM with the microG replacement layer"
							>
								<span class="plexus-card-lbl">microG</span>
								<span
									class={scoreClass(
										plexusData!.scores.micro_g.numerator,
										plexusData!.scores.micro_g.denominator,
									)}
								>
									{plexusData!.scores.micro_g.numerator.toFixed(2)}
									<span class="score-denom">
										/ {plexusData!.scores.micro_g.denominator}
									</span>
								</span>
								<span class="plexus-card-meta">
									{plexusData!.scores.micro_g.total_count} ratings
								</span>
							</div>
						)}
					</div>
					{plexusData!.roms.length > 0 && (
						<ul class="plexus-roms">
							{plexusData!.roms.map((rom) => (
								<li title={romTooltip(rom)}>
									<span class="rom-name">{rom.rom_name}</span>
									<span class="rom-type">{ratingLabel(rom.rating_type)}</span>
									<span class={scoreClass(rom.avg, rom.denominator)}>
										{rom.avg.toFixed(1)} / {rom.denominator}
									</span>
									<span class="rom-count">({rom.count})</span>
								</li>
							))}
						</ul>
					)}
					<p class="plexus-meta">
						{tested && <Fragment>Tested on {tested} · </Fragment>}
						Updated {formatDate(plexusData!.updated_at)} ·{' '}
						<a href={plexusData!.link} target="_blank" rel="noopener">
							View on Plexus →
						</a>
					</p>
				</div>
			)
		}
	</div>

	<div class="right">
		{
			hasAndroid && (
				<Fragment>
					<div class="info-section">
						<h4>Trackers</h4>
						{(androidData!.trackers || []).length === 0 && (
							<p class="all-good">
								<FontAwesome iconName="noTrackers" />
								No trackers found
							</p>
						)}
						<ul class="list trackers">
							{(androidData!.trackers || []).map((track) => (
								<li
									title={[
										track.categories?.length &&
											`Categories: ${track.categories.join(', ')}`,
										track.code_signature &&
											`Signature: ${track.code_signature}`,
									]
										.filter(Boolean)
										.join(' · ')}
								>
									<FontAwesome iconName="warning" />
									{track.name}
									{track.website && (
										<a
											class="tracker-link"
											href={track.website}
											target="_blank"
											rel="noopener"
											aria-label={`Open ${track.name} website`}
										>
											<FontAwesome iconName="externalLink" />
										</a>
									)}
								</li>
							))}
						</ul>
					</div>

					<div class="info-section">
						<h4>Permissions</h4>
						{(androidData!.permissions || []).length === 0 && (
							<p class="all-good">
								<FontAwesome iconName="noTrackers" />
								No permissions required
							</p>
						)}
						<ul class="list">
							{(androidData!.permissions || []).map((perm) => (
								<li title={perm}>{permissionToReadable(perm)}</li>
							))}
						</ul>
					</div>
				</Fragment>
			)
		}
	</div>
</div>

<style lang="scss">
	@use '../../styles/mixins' as *;

	.android-info-wrapper {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-lg);
		align-items: start;
		@media screen and (min-width: $bp-mobile) {
			grid-template-columns: 1fr 1fr;
		}
	}
	.left,
	.right {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
	}
	.info-section > h4 {
		margin-top: 0;
	}

	@include detail-info-base;

	ul {
		&.list-table li {
			.lbl {
				font-weight: 400;
			}
			.val {
				img {
					margin-right: var(--space-sm);
				}
			}
		}
		&.list {
			list-style: circle;
			padding-left: var(--space-md);
			margin: 0;
		}
		&.trackers {
			list-style: none;
			padding: 0;
		}
		&.trackers li {
			:global(svg:first-child) {
				color: var(--danger);
				width: 0.8em;
				height: 0.8em;
				margin-right: var(--space-xs);
			}
			.tracker-link {
				margin-left: var(--space-xs);
				opacity: var(--opacity-dim);
				&:hover {
					opacity: 1;
				}
				:global(svg) {
					width: 0.7em;
					height: 0.7em;
					color: var(--text-link);
				}
			}
		}
	}

	.all-good {
		color: var(--success);
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		:global(svg) {
			width: 1.5rem;
		}
	}

	.de-googled {
		.plexus-cards {
			display: flex;
			gap: var(--space-sm);
			margin-top: var(--space-sm);
			.plexus-card {
				flex: 1;
				display: flex;
				flex-direction: column;
				gap: var(--space-xs);
				padding: var(--space-sm);
				background: var(--background-form);
				border-radius: var(--curve-sm);
				.plexus-card-lbl {
					font-family: var(--font-subtitle);
					font-size: var(--text-sm);
					text-transform: uppercase;
					opacity: var(--opacity-soft);
				}
				.plexus-card-meta {
					font-size: var(--text-xs);
					opacity: var(--opacity-muted);
				}
			}
		}
		.score {
			font-family: var(--font-subtitle);
			font-size: var(--text-lg);
			line-height: var(--text-lg);
			font-weight: bold;
			.score-denom {
				font-size: var(--text-sm);
				font-weight: normal;
				opacity: var(--opacity-muted);
			}
			&.score-good {
				color: var(--success);
			}
			&.score-okay {
				color: var(--accent-2);
			}
			&.score-bad {
				color: var(--danger);
			}
		}
		.plexus-roms {
			list-style: none;
			padding-left: 0;
			font-size: var(--text-sm);
			margin: var(--space-sm) 0 0 0;
			li {
				display: grid;
				grid-template-columns: 1fr auto auto auto;
				gap: var(--space-sm);
				align-items: center;
				padding: 0.15rem 0;
				&:not(:last-child) {
					border-bottom: 1px solid var(--accent-3-translucent);
				}
			}
			.rom-name {
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}
			.rom-type {
				font-family: var(--font-subtitle);
				font-size: var(--text-xs);
				padding: 0.05rem 0.35rem;
				border-radius: var(--curve-sm);
				background: var(--accent-3-translucent);
				text-transform: uppercase;
			}
			.score {
				font-size: var(--text-sm);
			}
			.rom-count {
				opacity: var(--opacity-muted);
				font-size: var(--text-xs);
			}
		}
		.plexus-meta {
			margin-top: var(--space-sm);
			font-size: var(--text-sm);
			opacity: var(--opacity-soft);
		}
	}
</style>
