		"@types/js-yaml": "^4.0.9",
		"@types/node": "^22.0.0",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-astro": "^1.7.0",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-svelte": "^3.5.2",
		"sass": "^1.99.0",
		"svelte-eslint-parser": "^1.6.1",
		"typescript-eslint": "^8.59.3",
		"vitest": "^4.1.6"
