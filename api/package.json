{
  "name": "awesome-privacy-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:data": "bun run scripts/build-data.ts",
    "build": "bun run build:data && wrangler deploy --dry-run --outdir dist",
    "predev": "bun run build:data",
    "dev": "bun run --watch src/index.node.ts",
    "dev:workers": "bun run build:data && wrangler dev --port 8788",
    "start": "bun run src/index.node.ts",
    "deploy": "bun run build:data && wrangler deploy",
    "lint": "oxlint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "smoke": "bash tests/smoke.sh",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@hono/zod-openapi": "^0.18.4",
    "@modelcontextprotocol/sdk": "^1.6.1",
    "@scalar/hono-api-reference": "^0.10.20",
    "hono": "^4.6.16",
    "minisearch": "^7.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@types/bun": "^1.1.14",
    "@types/js-yaml": "^4.0.9",
    "js-yaml": "^4.1.0",
    "miniflare": "^3.20241218.0",
    "oxlint": "^0.15.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0"
  }
}
